# Server
PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mister
PGSSL=false

# JWT
JWT_SECRET=replace_with_long_random_string
JWT_EXPIRES_IN=7d

# Google OAuth (Google Cloud Console -> Credentials -> OAuth Client ID, Web application)
GOOGLE_CLIENT_ID=replace_me.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=replace_me

# Stripe Connect (dashboard.stripe.com -> Developers -> API keys)
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
PLATFORM_FEE_PERCENT=10

# Cloudinary (cloudinary.com -> Dashboard)
CLOUDINARY_CLOUD_NAME=replace_me
CLOUDINARY_API_KEY=replace_me
CLOUDINARY_API_SECRET=replace_me

# Mapbox (account.mapbox.com -> Tokens) — used by frontend, listed here for reference
MAPBOX_ACCESS_TOKEN=replace_me

# Resend (resend.com -> API Keys)
RESEND_API_KEY=re_replace_me
EMAIL_FROM="Mister <no-reply@mister.app>"
